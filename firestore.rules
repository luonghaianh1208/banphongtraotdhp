rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function getUserRole() {
      // Check if user exists in users collection first
      let isUser = exists(/databases/$(database)/documents/users/$(request.auth.uid));
      return isUser ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : null;
    }
    function isAdmin() { return getUserRole() == 'admin'; }
    function isManager() { return getUserRole() == 'manager'; }
    function isAuthenticated() { return request.auth != null; }
    function isAdminOrManager() { return isAdmin() || isManager(); }
    
    function isUnit() {
      return exists(/databases/$(database)/documents/units/$(request.auth.uid));
    }

    // Kiểm tra assignee chỉ sửa các field được phép
    function isAssigneeAllowedUpdate() {
      let allowed = ['notes', 'attachments', 'status', 'submittedBy', 'submittedAt', 'updatedAt', 'editHistory'];
      return request.auth.uid in resource.data.assignees
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if false;
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isAdminOrManager() || request.resource.data.createdBy == request.auth.uid);
      allow update: if isAuthenticated() && (
        isAdminOrManager()
        || resource.data.createdBy == request.auth.uid
        || isAssigneeAllowedUpdate()
      );
      allow delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow delete: if false;
    }

    match /penalties/{penaltyId} {
      allow read: if isAuthenticated();
      allow create: if isAdminOrManager();
      allow update: if isAdminOrManager();
      allow delete: if isAdminOrManager();
    }

    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /units/{unitId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /criteriaSets/{setId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrManager();
    }

    match /submissionPeriods/{periodId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrManager();
    }

    match /submissions/{subId} {
      allow read: if isAuthenticated();
      allow create: if isUnit() && request.resource.data.unitId == request.auth.uid;
      allow update: if isAdminOrManager() || (isUnit() && resource.data.unitId == request.auth.uid);
      allow delete: if isAdminOrManager();
    }

    match /plans/{planId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrManager();
    }

    match /contestEntries/{entryId} {
      allow read: if isAuthenticated();
      allow create: if isUnit() && request.resource.data.unitId == request.auth.uid;
      allow update: if isAdminOrManager() || (isUnit() && resource.data.unitId == request.auth.uid);
      allow delete: if isAdminOrManager();
    }

    match /criteriaAssignments/{assignId} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrManager();
    }

    match /criteriaSubmissions/{subId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdminOrManager();
    }
  }
}
